# Riot API Key - obter em https://developer.riotgames.com
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# PostgreSQL - Railway preenche automaticamente DATABASE_URL
DATABASE_URL=postgresql://user:password@host:port/database

# Porta (Railway preenche automaticamente)
PORT=3000

# Ambiente
NODE_ENV=development
